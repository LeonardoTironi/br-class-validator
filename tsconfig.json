{
    "compilerOptions": {
        "strict": true,
        "esModuleInterop": true,
        "target": "ES2022",
        "moduleResolution": "Node",
        "module": "CommonJS",
        "isolatedModules": true,
        "outDir": "./dist",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}